{
  "title": "Migration Platform — Overview",
  "uid": "migration-overview",
  "tags": ["migration", "cdc"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "15s",
  "time": { "from": "now-1h", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "project",
        "label": "Project",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "query": "label_values(migration_connector_up, project)",
        "includeAll": true,
        "multi": true,
        "refresh": 2,
        "current": { "text": "All", "value": "$__all" }
      }
    ]
  },
  "panels": [
    {
      "type": "stat",
      "title": "Active jobs",
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "migration_active_jobs", "refId": "A" }],
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "steps": [{ "color": "green", "value": null }] } } }
    },
    {
      "type": "stat",
      "title": "Alerts firing",
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "migration_alerts_firing", "refId": "A" }],
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "red", "value": 1 }] } } }
    },
    {
      "type": "stat",
      "title": "Connectors up",
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "sum(migration_connector_up{project=~\"$project\"})", "refId": "A" }],
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "steps": [{ "color": "red", "value": null }, { "color": "green", "value": 1 }] } } }
    },
    {
      "type": "timeseries",
      "title": "Sink lag (records) — per project",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "migration_sink_lag_records{project=~\"$project\"}", "legendFormat": "{{project}}", "refId": "A" }],
      "fieldConfig": { "defaults": { "custom": { "drawStyle": "line", "fillOpacity": 10 }, "unit": "short" } }
    },
    {
      "type": "state-timeline",
      "title": "Connector state (1=RUNNING)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "migration_connector_up{project=~\"$project\"}", "legendFormat": "{{project}}/{{role}}", "refId": "A" }],
      "fieldConfig": { "defaults": { "thresholds": { "steps": [{ "color": "red", "value": null }, { "color": "green", "value": 1 }] }, "max": 1, "min": 0 } }
    },
    {
      "type": "timeseries",
      "title": "Jobs by status",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "migration_jobs", "legendFormat": "{{status}}", "refId": "A" }],
      "fieldConfig": { "defaults": { "custom": { "drawStyle": "bars", "fillOpacity": 40, "stacking": { "mode": "normal" } } } }
    },
    {
      "type": "timeseries",
      "title": "API request rate & errors (req/s)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "sum(rate(http_server_requests_seconds_count[5m]))", "legendFormat": "all", "refId": "A" },
        { "expr": "sum(rate(http_server_requests_seconds_count{status=~\"5..\"}[5m]))", "legendFormat": "5xx errors", "refId": "B" }
      ],
      "fieldConfig": { "defaults": { "custom": { "drawStyle": "line", "fillOpacity": 10 }, "unit": "reqps" } }
    },
    {
      "type": "timeseries",
      "title": "JVM heap used",
      "gridPos": { "h": 7, "w": 12, "x": 0, "y": 20 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "sum(jvm_memory_used_bytes{area=\"heap\"})", "legendFormat": "heap", "refId": "A" }],
      "fieldConfig": { "defaults": { "unit": "bytes", "custom": { "drawStyle": "line", "fillOpacity": 10 } } }
    },
    {
      "type": "logs",
      "title": "Control-plane logs (Loki)",
      "gridPos": { "h": 7, "w": 12, "x": 12, "y": 20 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [{ "expr": "{service=\"migration-platform\"}", "refId": "A" }]
    }
  ]
}
